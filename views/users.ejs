<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RideFlow Manage Users</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

:root{
--bg:#0b0b0f;
--card:#14141c;
--card2:#1a1a24;
--line:#2a2a38;
--purple:#8b5cf6;
--purple2:#a855f7;
--blue:#3b82f6;
--green:#22c55e;
--red:#ef4444;
--text:#ffffff;
--muted:#9ca3af;
}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Segoe UI,sans-serif;
background:linear-gradient(135deg,#08080c,#11111a,#181825);
color:white;
overflow-x:hidden;
}

/* SIDEBAR */

.sidebar{
position:fixed;
top:0;
left:0;
width:250px;
height:100vh;
background:rgba(20,20,28,.96);
border-right:1px solid var(--line);
padding:28px 18px;
}

.brand{
font-size:28px;
font-weight:700;
color:var(--purple2);
margin-bottom:35px;
}

.nav-item{
display:block;
padding:14px 16px;
margin-bottom:10px;
border-radius:14px;
text-decoration:none;
color:#d1d5db;
transition:.25s;
}

.nav-item:hover,
.nav-item.active{
background:linear-gradient(90deg,var(--purple),#6d28d9);
transform:translateX(4px);
color:white;
}

/* MAIN */

.main{
margin-left:250px;
padding:30px;
}

.title{
font-size:52px;
font-weight:700;
color:var(--purple2);
margin-bottom:6px;
}

.small-muted{
color:var(--muted);
font-size:14px;
margin-bottom:25px;
}

/* SEARCH */

.search-box{
width:340px;
max-width:100%;
padding:13px 16px;
border-radius:14px;
border:1px solid var(--line);
background:#0f0f15;
color:white;
outline:none;
margin-bottom:25px;
}

.search-box::placeholder{
color:#8b8b95;
}

/* CARDS */

.card-box{
background:linear-gradient(180deg,var(--card),var(--card2));
border:1px solid var(--line);
border-radius:22px;
padding:24px;
margin-bottom:25px;
}

/* FORM */

.form-control,
.form-select{
background:#0f0f15 !important;
border:1px solid var(--line) !important;
color:white !important;
border-radius:14px !important;
padding:12px 14px !important;
}

.form-control:focus,
.form-select:focus{
box-shadow:none !important;
border-color:var(--purple) !important;
background:#0f0f15 !important;
color:white !important;
}

.form-control::placeholder{
color:#8b8b95 !important;
}

/* Autofill fix */

input:-webkit-autofill,
input:-webkit-autofill:hover,
input:-webkit-autofill:focus,
select:-webkit-autofill{
-webkit-box-shadow:0 0 0 1000px #0f0f15 inset !important;
-webkit-text-fill-color:white !important;
caret-color:white !important;
transition:background-color 5000s ease-in-out 0s;
}

.btn-add{
background:linear-gradient(90deg,var(--green),#16a34a);
border:none;
color:white;
padding:12px;
font-weight:700;
border-radius:14px;
width:100%;
}

/* TABLE */

.table-wrap{
overflow:auto;
border-radius:18px;
}

table{
width:100%;
min-width:1050px;
border-collapse:collapse;
}

thead{
background:rgba(255,255,255,.03);
}

thead th{
padding:18px 16px;
font-size:14px;
color:var(--muted);
border-bottom:1px solid rgba(255,255,255,.08);
}

tbody td{
padding:18px 16px;
border-bottom:1px solid rgba(255,255,255,.04);
color:white;
background:transparent;
}

tbody tr:hover{
background:rgba(255,255,255,.02);
}

/* BADGES */

.badge-pill{
padding:8px 14px;
border-radius:999px;
font-size:12px;
font-weight:600;
display:inline-block;
text-transform:capitalize;
}

.rider{
background:rgba(59,130,246,.15);
color:#60a5fa;
}

.driver{
background:rgba(34,197,94,.15);
color:#4ade80;
}

.admin,
.super_admin{
background:rgba(168,85,247,.15);
color:#c084fc;
}

.active{
background:rgba(34,197,94,.15);
color:#4ade80;
}

.suspended,
.banned{
background:rgba(239,68,68,.15);
color:#f87171;
}

/* ACTION BUTTONS */

.btn-action{
padding:8px 14px;
font-size:12px;
font-weight:700;
border:none;
border-radius:10px;
text-decoration:none;
display:inline-block;
color:white;
}

.btn-suspend{
background:#ef4444;
}

.btn-activate{
background:#22c55e;
}

/* MOBILE */

@media(max-width:992px){

.sidebar{
display:none;
}

.main{
margin-left:0;
padding:20px;
}

.title{
font-size:38px;
}

}

</style>
</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

<div class="brand">RideFlow</div>

<a href="/admin" class="nav-item">🏠 Dashboard</a>
<a href="/reports" class="nav-item">📈 Reports</a>
<a href="/users" class="nav-item active">👤 Users</a>
<a href="/driver" class="nav-item">🚗 Drivers</a>
<a href="/reports" class="nav-item">💳 Payments</a>
<a href="/" class="nav-item">🚪 Logout</a>

</div>

<!-- MAIN -->

<div class="main">

<h1 class="title">Manage Users</h1>
<div class="small-muted">Live data fetched from MySQL database</div>

<input type="text" id="searchInput" class="search-box" placeholder="Search users...">

<!-- ADD USER -->

<div class="card-box">

<h3 class="mb-4">Add New User</h3>

<form action="/add-user" method="POST">

<div class="row g-3">

<div class="col-md-6">
<input type="text" name="full_name" class="form-control" placeholder="Full Name" required>
</div>

<div class="col-md-6">
<input type="email" name="email" class="form-control" placeholder="Email Address" required>
</div>

<div class="col-md-6">
<input type="text" name="phone_number" class="form-control" placeholder="Phone Number" required>
</div>

<div class="col-md-6">
<input type="password" name="password" class="form-control" placeholder="Password" required>
</div>

<div class="col-md-6">
<select name="role" class="form-select" required>
<option value="rider">Rider</option>
<option value="driver">Driver</option>
<option value="admin">Admin</option>
</select>
</div>

<div class="col-md-6">
<button type="submit" class="btn-add">Add User</button>
</div>

</div>

</form>

</div>

<!-- USERS TABLE -->

<div class="card-box">

<div class="table-wrap">

<table>

<thead>
<tr>
<th>#</th>
<th>Name</th>
<th>Email</th>
<th>Role</th>
<th>Status</th>
<th>Action</th>
</tr>
</thead>

<tbody id="usersTable">

<% users.forEach((user, index) => { %>

<tr>

<td><%= index + 1 %></td>
<td><%= user.full_name %></td>
<td><%= user.email %></td>

<td>
<span class="badge-pill <%= user.role %>">
<%= user.role %>
</span>
</td>

<td>
<span class="badge-pill <%= user.account_status %>">
<%= user.account_status %>
</span>
</td>

<td>

<% if(user.account_status === 'active'){ %>

<a href="/suspend/<%= user.user_id %>" class="btn-action btn-suspend">
Suspend
</a>

<% } else { %>

<a href="/activate/<%= user.user_id %>" class="btn-action btn-activate">
Activate
</a>

<% } %>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</div>

</div>

<script>

const searchInput = document.getElementById("searchInput");
const tableRows = document.querySelectorAll("#usersTable tr");

searchInput.addEventListener("keyup", function(){

let value = this.value.toLowerCase();

tableRows.forEach(row => {

let text = row.innerText.toLowerCase();

if(text.includes(value)){
row.style.display = "";
}else{
row.style.display = "none";
}

});

});

</script>

</body>
</html>
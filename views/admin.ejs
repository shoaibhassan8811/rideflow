<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RideFlow Admin Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

:root{
--bg:#0b0b0f;
--card:#14141c;
--card2:#1a1a24;
--line:#2a2a38;
--purple:#8b5cf6;
--purple2:#a855f7;
--blue:#3b82f6;
--green:#22c55e;
--red:#ef4444;
--text:#ffffff;
--muted:#9ca3af;
}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Segoe UI,sans-serif;
background:linear-gradient(135deg,#08080c,#11111a,#181825);
color:white;
overflow-x:hidden;
}

/* SIDEBAR */

.sidebar{
position:fixed;
top:0;
left:0;
width:250px;
height:100vh;
background:rgba(20,20,28,.96);
border-right:1px solid var(--line);
padding:28px 18px;
}

.brand{
font-size:28px;
font-weight:700;
color:var(--purple2);
margin-bottom:35px;
}

.nav-item{
display:block;
padding:14px 16px;
margin-bottom:10px;
border-radius:14px;
text-decoration:none;
color:#d1d5db;
transition:.25s;
}

.nav-item:hover,
.nav-item.active{
background:linear-gradient(90deg,var(--purple),#6d28d9);
transform:translateX(4px);
color:white;
}

/* MAIN */

.main{
margin-left:250px;
padding:30px;
}

.title{
font-size:52px;
font-weight:700;
color:var(--purple2);
margin-bottom:8px;
}

.sub{
color:var(--muted);
margin-bottom:28px;
font-size:15px;
}

/* CARDS */

.card-box{
background:linear-gradient(180deg,var(--card),var(--card2));
border:1px solid var(--line);
border-radius:22px;
padding:25px;
height:100%;
transition:.25s;
}

.card-box:hover{
transform:translateY(-4px);
}

.label{
font-size:14px;
color:var(--muted);
margin-bottom:12px;
}

.value{
font-size:42px;
font-weight:700;
color:white;
}

/* ACTIONS */

.action-card{
background:linear-gradient(180deg,var(--card),var(--card2));
border:1px solid var(--line);
border-radius:22px;
padding:28px;
margin-top:28px;
}

.action-title{
font-size:30px;
font-weight:700;
margin-bottom:20px;
}

.quick-links{
display:flex;
gap:14px;
flex-wrap:wrap;
}

.quick-links a{
padding:12px 20px;
border-radius:14px;
text-decoration:none;
font-weight:700;
font-size:14px;
color:white;
transition:.25s;
}

.quick-links a:hover{
transform:translateY(-2px);
opacity:.95;
}

.users-btn{
background:linear-gradient(90deg,var(--purple),#7c3aed);
}

.report-btn{
background:linear-gradient(90deg,var(--blue),#2563eb);
}

.logout-btn{
background:linear-gradient(90deg,var(--red),#dc2626);
}

/* MOBILE */

@media(max-width:992px){

.sidebar{
display:none;
}

.main{
margin-left:0;
padding:20px;
}

.title{
font-size:38px;
}

}

</style>
</head>

<body>

<!-- SIDEBAR -->

<div class="sidebar">

<div class="brand">RideFlow</div>

<a href="/admin" class="nav-item active">🏠 Dashboard</a>
<a href="/reports" class="nav-item">📈 Reports</a>
<a href="/users" class="nav-item">👤 Users</a>
<a href="/driver" class="nav-item">🚗 Drivers</a>
<a href="/reports" class="nav-item">💳 Payments</a>
<a href="/" class="nav-item">🚪 Logout</a>

</div>

<!-- MAIN -->

<div class="main">

<h1 class="title">Admin Dashboard</h1>
<div class="sub">Live system statistics from RideFlow database</div>

<div class="row g-4">

<div class="col-md-3">
<div class="card-box">
<div class="label">Total Users</div>
<div class="value"><%= stats.totalUsers %></div>
</div>
</div>

<div class="col-md-3">
<div class="card-box">
<div class="label">Total Riders</div>
<div class="value"><%= stats.totalRiders %></div>
</div>
</div>

<div class="col-md-3">
<div class="card-box">
<div class="label">Total Drivers</div>
<div class="value"><%= stats.totalDrivers %></div>
</div>
</div>

<div class="col-md-3">
<div class="card-box">
<div class="label">Suspended Users</div>
<div class="value"><%= stats.suspendedUsers %></div>
</div>
</div>

</div>

<!-- QUICK ACTIONS -->

<div class="action-card">

<div class="action-title">Quick Actions</div>

<div class="quick-links">

<a href="/users" class="users-btn">Manage Users</a>
<a href="/reports" class="report-btn">Reports</a>
<a href="/" class="logout-btn">Logout</a>

</div>

</div>

</div>

</body>
</html>